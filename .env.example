# ─── AI 연동 설정 ───────────────────────────────────────────
# [현재] Anthropic API 사용 시
ANTHROPIC_API_KEY=your_api_key_here

# [변경] Azure OpenAI 사용 시 아래 4개 입력 후 agent.ts 교체
# AZURE_OPENAI_ENDPOINT=https://회사명.openai.azure.com
# AZURE_OPENAI_API_KEY=발급받은키
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ─── Oracle DB ───────────────────────────────────────────────
ORACLE_URL=jdbc:oracle:thin:@localhost:1521/XEPDB1
ORACLE_USER=planbridge
ORACLE_PASSWORD=password

# ─── 기타 설정 ───────────────────────────────────────────────
REPOS_BASE_PATH=/repos
API_SERVER_URL=http://localhost:8080
POLL_INTERVAL_MS=5000
